# Copy this file to .env in the same directory (srcs/.env) and fill in real values.
# Never commit srcs/.env.

DOMAIN_NAME=yourlogin.42.fr

MYSQL_DATABASE=wordpress
MYSQL_USER=yourlogin
MYSQL_PASSWORD=CHANGEME_DB_USER
MYSQL_ROOT_PASSWORD=CHANGEME_DB_ROOT

# Admin username must NOT contain admin / Admin / administrator (subject rule).
WP_ADMIN_USER=yourlogin_owner
WP_ADMIN_PASSWORD=CHANGEME_WP_ADMIN
WP_ADMIN_EMAIL=you@student.42.fr

WP_USER=editor_user
WP_USER_PASSWORD=CHANGEME_WP_EDITOR
WP_USER_EMAIL=editor@example.com

# Host path for named volumes (bind-backed local driver). Must be /home/<login>/data
HOST_VOLUME_PATH=/home/yourlogin/data
