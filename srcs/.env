# ==========================================
# SYSTEM SETUP
# ==========================================
# The domain name required by the subject to route traffic to your local machine.
# It must be your intra login followed by .42.fr.
DOMAIN_NAME=malaamir.42.fr

# ==========================================
# MARIADB SETUP
# ==========================================
# The name of the database that WordPress will use to store all its data.
MYSQL_DATABASE=wordpress

# The standard database user that WordPress will use to connect to MariaDB.
MYSQL_USER=malaamir

# The password for the standard database user (MYSQL_USER).
MYSQL_PASSWORD=1417

# The absolute master password for the database server itself. 
# Used by the root user to create databases and grant permissions behind the scenes.
MYSQL_ROOT_PASSWORD=root1417

# ==========================================
# WORDPRESS SETUP
# ==========================================

# User 1: The Administrator
# The username for the WordPress admin account. 
# (Changed to remove the word 'admin' to comply with subject rules).
WP_ADMIN_USER=malaamir_vip

# The password for the WordPress admin account.
WP_ADMIN_PASSWORD=vip1417

# The email address associated with the WordPress admin account.
WP_ADMIN_EMAIL=malaamir@student.1337.ma

# User 2: The Standard User
# The username for the secondary, non-admin WordPress account. 
# (The subject explicitly requires at least two users).
WP_USER=standard_user

# The password for the standard WordPress user.
WP_USER_PASSWORD=standard1417

# The email address associated with the standard WordPress account.
WP_USER_EMAIL=standard_user@gmail.com


HOST_VOLUME_PATH=/home/malaamir/data